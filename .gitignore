.playwright-mcp/

# Screenshots / scratch images (not part of source)
*.jpeg

# HTML documents (generated/exported)
docs/*.html
!docs/project-overview.html

# Plans (session-specific, not for version control)
docs/plans/

# Temporary
*.zip
/tmp/
