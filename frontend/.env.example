# Cognito Configuration
# deploy.sh 실행 시 자동 생성됩니다. 수동 배포 시 CloudFormation Outputs에서 값을 복사하세요.
# - CognitoUserPoolId → VITE_COGNITO_USER_POOL_ID
# - CognitoClientId → VITE_COGNITO_CLIENT_ID (PKCE OAuth 클라이언트)
# - CognitoDomain → VITE_COGNITO_DOMAIN (https:// 제외한 호스트명)
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=myapp-dev-123456789012.auth.ap-northeast-2.amazoncognito.com
VITE_COGNITO_REGION=ap-northeast-2

# API Configuration (optional, defaults to /api)
VITE_API_BASE_URL=/api
